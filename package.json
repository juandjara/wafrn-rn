{
  "name": "wafrn-rn",
  "main": "expo-router/entry",
  "version": "1.12.0",
  "scripts": {
    "update:preview_ci": "npx eas-cli update --channel preview --auto --non-interactive --environment preview",
    "update:preview": "npx eas-cli update --channel preview --auto --environment preview",
    "build:dev:ios": "NODE_ENV=development npx eas-cli build --profile development --local --platform ios",
    "build:dev:android": "bash ./scripts/android_build.sh dev",
    "build:prod:ios": "fastlane beta",
    "build:prod:android": "bash ./scripts/android_build.sh prod-foss",
    "build:prod:google": "bash ./scripts/android_build.sh prod-google",
    "setup:dev": "NODE_ENV=development expo prebuild",
    "setup:prod": "NODE_ENV=production expo prebuild && bash ./scripts/sed_gradle_version.sh",
    "start": "NODE_ENV=development expo start",
    "android:clean": "rm -rf android/build android/app/build android/app/.cxx",
    "android": "npm run setup:dev && npm run android:clean && NODE_ENV=development expo run:android --app-id dev.djara.wafrn_rn.dev",
    "ios": "NODE_ENV=development expo run:ios",
    "lint": "expo lint --fix",
    "tsc": "tsc",
    "prepare": "npm run instances",
    "instances": "node scripts/downloadInstances.ts",
    "check-env": "node scripts/checkEnvironment.ts",
    "preversion": "npm run check-env",
    "version": "npm run setup:prod && git add -A .",
    "postversion": "git push && git push origin $(git describe --tags)"
  },
